# WattWise Admin Portal - Environment Configuration
# Copy this file to .env and update with actual values

# Database Configuration
DATABASE_URL=postgresql://admin:password@localhost:5432/wattwise_admin
# For SQLite (development): sqlite:///./test.db

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email Configuration (for OTP sending)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@wattwise.com
SENDER_NAME=WattWise Admin

# Application Configuration
APP_NAME=WattWise Admin Portal API
APP_VERSION=1.0.0
DEBUG=False

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://meter-zen-portal.lovable.app

# Logging
LOG_LEVEL=INFO

